# ─── Anthropic Claude API ──────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Supabase ──────────────────────────────
# 프로젝트 Settings → API 에서 복사
SUPABASE_URL=https://xxxxx.supabase.co
# service_role 키 (절대 클라이언트 노출 금지)
SUPABASE_SERVICE_KEY=eyJxxxxx

# ─── JWT 시크릿 (32자 이상 랜덤) ────────────
JWT_SECRET=change-this-to-random-32-chars-or-more

# ─── 관리자 초기 계정 ──────────────────────
ADMIN_EMAIL=admin@basecamp.local
ADMIN_PASSWORD=change-this-after-first-login

# ─── 정책 ───────────────────────────────────
RETENTION_DAYS=30
K_ANONYMITY=5

# ─── 로컬 개발 전용 ────────────────────────
PORT=3000
